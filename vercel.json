{
  "buildCommand": "go build -ldflags=\"-s -w\" -o bin/light-simulator ./cmd/server",
  "outputDirectory": "web/static",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/uploads/:path*", "destination": "/uploads/:path*" },
    { "source": "/static/:path*", "destination": "/static/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
